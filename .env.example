APP_NAME=SafetyMAIN API
APP_VERSION=0.1.0
APP_ENV=development

# PostgreSQL connection string used by persistence and readiness checks.
# Never expose this value in API responses or client-facing logs.
DATABASE_URL=postgresql+psycopg://safetymain:safetymain@localhost:5432/safetymain

# Comma-separated browser origins. Empty means CORS middleware is not enabled.
# Do not use "*" together with credentials.
CORS_ALLOWED_ORIGINS=
